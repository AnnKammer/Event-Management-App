<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="uk.ac.aru.campusevents.controller.OrganizerEventDetailsController"
            prefWidth="480" prefHeight="320">

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <content>
                <VBox spacing="10">
                    <padding>
                        <Insets top="12" left="16" right="16" bottom="10"/>
                    </padding>

                    <Label text="Event Details"
                           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                    <GridPane hgap="8" vgap="6">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="30"/>
                            <ColumnConstraints percentWidth="70"/>
                        </columnConstraints>

                        <children>
                            <Label text="Title:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="titleLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                            <Label text="Status:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="statusLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                            <Label text="Date:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="dateLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                            <Label text="Location:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <Label fx:id="locationLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                            <Label text="Capacity:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <Label fx:id="capacityLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                            <Label text="Organiser:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <Label fx:id="organiserLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                        </children>
                    </GridPane>

                    <Separator/>

                    <HBox spacing="20">
                        <Label text="Registered / Approved:"/>
                        <Label fx:id="registeredCountLabel" style="-fx-font-weight: bold;"/>

                        <Label text="Waitlist:"/>
                        <Label fx:id="waitlistCountLabel" style="-fx-font-weight: bold;"/>
                    </HBox>

                    <Separator/>

                    <Label text="Feedback"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

                    <HBox spacing="10">
                        <Label fx:id="avgRatingLabel" text="Average rating: N/A"/>
                        <Label fx:id="feedbackCountLabel" text="Total feedback: 0"/>
                    </HBox>

                    <TextArea fx:id="feedbackListArea"
                              editable="false"
                              prefRowCount="8"
                              wrapText="true"
                              VBox.vgrow="ALWAYS"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <padding>
                <Insets right="16" bottom="10"/>
            </padding>
            <Button fx:id="exportCsvButton"
                    text="Export registrations (CSV)"
                    onAction="#handleExportCsv"/>
            <Button fx:id="closeButton"
                    text="Close"
                    onAction="#handleClose"/>
        </HBox>
    </bottom>
</BorderPane>
