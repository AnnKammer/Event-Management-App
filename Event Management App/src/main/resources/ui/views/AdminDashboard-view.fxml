<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="uk.ac.aru.campusevents.controller.AdminDashboardController"
            prefWidth="900" prefHeight="600">

    <!-- Top navigation bar -->
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Button fx:id="upcomingBtn"
                    text="Upcoming"
                    onAction="#goUpcoming"
                    style="-fx-font-size: 14px;"/>

            <Button fx:id="studentBtn"
                    text="Student"
                    onAction="#goStudent"
                    style="-fx-font-size: 14px;"/>

            <Button fx:id="organizerBtn"
                    text="Organizer"
                    onAction="#goOrganizer"
                    style="-fx-font-size: 14px;"/>

            <Button fx:id="adminBtn"
                    text="Admin"
                    onAction="#goAdmin"
                    style="-fx-font-size: 14px;"/>

            <Pane HBox.hgrow="ALWAYS"/>
        </HBox>

    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10" left="15" right="15" bottom="15"/>
            </padding>

            <!-- Title -->
            <Label text="Admin Dashboard"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

            <!-- Filters -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Status:"/>
                <ComboBox fx:id="statusFilter" prefWidth="150"/>

                <Label text="Category:"/>
                <ComboBox fx:id="categoryFilter" prefWidth="150"/>
            </HBox>

            <!-- Events table -->
            <TableView fx:id="eventsTable"
                       VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameCol"
                                 text="Name"
                                 prefWidth="220"/>

                    <TableColumn fx:id="statusCol"
                                 text="Status"
                                 prefWidth="110"/>

                    <TableColumn fx:id="organizerCol"
                                 text="Organizer"
                                 prefWidth="150"/>

                    <TableColumn fx:id="dateCol"
                                 text="Date"
                                 prefWidth="150"/>

                    <TableColumn fx:id="locationCol"
                                 text="Location"
                                 prefWidth="160"/>
                </columns>
            </TableView>

            <!-- Admin actions -->
            <HBox spacing="8" alignment="CENTER_RIGHT">
                <Button text="Set OPEN"       onAction="#handleSetOpen"/>
                <Button text="Set FULL"       onAction="#handleSetFull"/>
                <Button text="Set COMPLETED"  onAction="#handleSetCompleted"/>
                <Button text="Set ARCHIVED"   onAction="#handleSetArchived"/>
                <Button text="Set CANCELLED"  onAction="#handleSetCancelled"/>

                <Button text="Delete Event"
                        onAction="#handleDeleteEvent"
                        style="-fx-background-color: #ff6666;"/>

                <Button text="Audit Logs"
                        onAction="#openAuditLogs"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
